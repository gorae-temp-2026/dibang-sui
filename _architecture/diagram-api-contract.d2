direction: right

endpoints: {
  label: "API Endpoints"

  Users: {
    label: "Users"

    getMe: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/users/me"
      policy: "owner"
      summary: "내 프로필 조회"
    }
    updateMe: {
      shape: sql_table
      style.fill: "#f59e0b"
      method: "PATCH"
      path: "/users/me"
      policy: "owner"
      summary: "내 프로필 수정"
    }
    getUser: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/users/{userId}"
      policy: "unknown"
      summary: "[우선 구현 예정·이름 마스킹 의존] [authenticated] 사용자 공개 프로필 조회"
    }
    getMyWeddings: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/users/me/weddings"
      policy: "owner"
      summary: "내가 Host인 결혼식 목록"
    }
    getMyParticipatedWeddings: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/users/me/participated-weddings"
      policy: "authenticated"
      summary: "내가 참여한 결혼식 목록"
    }
    listMyIums: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/users/me/iums"
      policy: "unknown"
      summary: "[미구현·추후] [owner] 내 이음 목록"
    }
  }

  Weddings: {
    label: "Weddings"

    createWedding: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/weddings"
      policy: "authenticated"
      summary: "결혼식 만들기 (Lounge + GatherPlace + Invitation 포함)"
    }
    getWedding: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/weddings/{weddingId}"
      policy: "public"
      summary: "결혼식 상세 조회"
    }
    updateWedding: {
      shape: sql_table
      style.fill: "#f59e0b"
      method: "PATCH"
      path: "/weddings/{weddingId}"
      policy: "host"
      summary: "결혼식 정보 수정"
    }
  }

  Invitations: {
    label: "Invitations"

    createInvitation: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/weddings/{weddingId}/invitations"
      policy: "host"
      summary: "기존 결혼식에 청첩장 추가"
    }
    getInvitation: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/invitations/{slug}"
      policy: "public"
      summary: "공유 링크로 청첩장 조회"
    }
    heartInvitation: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/invitations/{slug}/heart"
      policy: "public"
      summary: "청첩장 하트"
    }
    updateInvitation: {
      shape: sql_table
      style.fill: "#f59e0b"
      method: "PATCH"
      path: "/weddings/{weddingId}/invitations/{invitationId}"
      policy: "host"
      summary: "청첩장 수정"
    }
    deleteInvitation: {
      shape: sql_table
      method: "DELETE"
      path: "/weddings/{weddingId}/invitations/{invitationId}"
      policy: "host"
      summary: "청첩장 삭제 (최소 1개 유지)"
    }
    shareInvitation: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/weddings/{weddingId}/invitations/{invitationId}/share"
      policy: "host"
      summary: "공유 링크 조회"
    }
    listMobileInvitationPhotos: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/weddings/{weddingId}/invitations/{invitationId}/photos"
      policy: "host"
      summary: "청첩장 사진 목록 (sub_kind, sort_order asc)"
    }
    createMobileInvitationPhoto: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/weddings/{weddingId}/invitations/{invitationId}/photos"
      policy: "host"
      summary: "청첩장 사진 등록 (presigned PUT 후 storage_path 메타 저장)"
    }
  }

  Lounges: {
    label: "Lounges"

    getLounge: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}"
      policy: "authenticated"
      summary: "라운지 정보 조회"
    }
    getMyLoungeCheckIn: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}/entries/mine"
      policy: "authenticated"
      summary: "내 라운지 입장 기록 조회"
    }
    createLoungeCheckIn: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/lounges/{loungeId}/entries"
      policy: "authenticated"
      summary: "라운지 입장 (LoungeCheckIn 생성)"
    }
    listSharedPhotos: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}/shared-photos"
      policy: "authenticated"
      summary: "공유 사진 목록. host = 라운지 전체, 입장자 = 본인 것만"
    }
    createSharedPhoto: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/lounges/{loungeId}/shared-photos"
      policy: "authenticated"
      summary: "공유 사진 등록. guest_user_id = ctx user 강제. 100장/하객 한도는 서버 트랜잭션 검증"
    }
    downloadSharedPhotosZip: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}/shared-photos/zip"
      policy: "host"
      summary: "하객 그룹별 공유 사진 일괄 ZIP 다운로드 (archive/zip 스트리밍)"
    }
  }

  Guestbook: {
    label: "Guestbook"

    listGuestbookEntries: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}/guestbook"
      policy: "public"
      summary: "방명록 목록"
    }
    createGuestbookEntry: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/lounges/{loungeId}/guestbook"
      policy: "public"
      summary: "방명록 작성"
    }
    getMyGuestbookEntry: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}/guestbook/mine"
      policy: "authenticated"
      summary: "내 방명록 조회"
    }
    createGuestbookMessage: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/guestbook/{entryId}/message"
      policy: "public"
      summary: "방명록 메세지 생성 (참석 기록에 연결)"
    }
    recordGuestbookMessageView: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/guestbook/messages/{messageId}/view"
      policy: "authenticated"
      summary: "피드(방명록 메세지) 조회 기록 — 본인 제외·중복 멱등"
    }
    claimGuestbookEntry: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/guestbook/{entryId}/claim"
      policy: "authenticated"
      summary: "비로그인 방명록을 현재 유저에 연결"
    }
  }

  Announcements: {
    label: "Announcements"

    listAnnouncements: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}/announcements"
      policy: "public"
      summary: "공지 목록"
    }
    createAnnouncement: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/lounges/{loungeId}/announcements"
      policy: "host"
      summary: "공지 발행"
    }
    updateAnnouncement: {
      shape: sql_table
      style.fill: "#f59e0b"
      method: "PATCH"
      path: "/announcements/{announcementId}"
      policy: "host"
      summary: "공지 수정"
    }
    deleteAnnouncement: {
      shape: sql_table
      method: "DELETE"
      path: "/announcements/{announcementId}"
      policy: "host"
      summary: "공지 삭제 (soft delete)"
    }
  }

  Feed: {
    label: "Feed"

    listFeed: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}/feed"
      policy: "authenticated"
      summary: "라운지 피드 통합 조회"
    }
  }

  FeedHearts: {
    label: "FeedHearts"

    toggleFeedHeart: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/feed-hearts"
      policy: "authenticated"
      summary: "피드 하트 토글"
    }
  }

  FeedComments: {
    label: "FeedComments"

    createFeedComment: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/feed-comments"
      policy: "authenticated"
      summary: "피드 댓글 작성"
    }
    listFeedComments: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/feed-comments"
      policy: "authenticated"
      summary: "피드 댓글 목록"
    }
    deleteFeedComment: {
      shape: sql_table
      method: "DELETE"
      path: "/feed-comments/{commentId}"
      policy: "authenticated"
      summary: "피드 댓글 삭제 (본인만)"
    }
  }

  GatherPlaces: {
    label: "GatherPlaces"

    getGatherPlace: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/gather-places/{placeId}"
      policy: "unknown"
      summary: "[미구현·추후] [public] MoiGatherPlace 상세"
    }
    listLoungeCheckIns: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/gather-places/{placeId}/check-ins"
      policy: "public"
      summary: "방문 모이 목록"
    }
  }

  InteriorItems: {
    label: "InteriorItems"

    listInteriorItems: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/gather-places/{placeId}/interior-items"
      policy: "unknown"
      summary: "[미구현·추후] [public] 인테리어 아이템 목록"
    }
    createInteriorItem: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/gather-places/{placeId}/interior-items"
      policy: "unknown"
      summary: "[미구현·추후] [host] 인테리어 아이템 추가"
    }
    placeInteriorItem: {
      shape: sql_table
      style.fill: "#f59e0b"
      method: "PATCH"
      path: "/interior-items/{itemId}/position"
      policy: "unknown"
      summary: "[미구현·추후] [host] 아이템 배치 (position 설정)"
    }
    unplaceInteriorItem: {
      shape: sql_table
      method: "DELETE"
      path: "/interior-items/{itemId}/position"
      policy: "unknown"
      summary: "[미구현·추후] [host] 아이템 배치 해제"
    }
  }

  Mois: {
    label: "Mois"

    getMyMoi: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/mois/me"
      policy: "unknown"
      summary: "[미구현·추후] [owner] 내 모이 조회"
    }
    getMoi: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/mois/{moiId}"
      policy: "unknown"
      summary: "[미구현·추후 — 재구현 시 §3 소유자 이름 마스킹 필수] [public] 특정 모이 조회"
    }
  }

  MoiItems: {
    label: "MoiItems"

    listMyMoiItems: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/mois/me/items"
      policy: "unknown"
      summary: "[미구현·추후] [owner] 내 모이 아이템 목록"
    }
    equipMoiItem: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/mois/me/items/{itemId}/equip"
      policy: "unknown"
      summary: "[미구현·추후] [owner] 모이 아이템 장착"
    }
    unequipMoiItem: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/mois/me/items/{itemId}/unequip"
      policy: "unknown"
      summary: "[미구현·추후] [owner] 모이 아이템 해제"
    }
    sendMoiItem: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/mois/me/items/{itemId}/send"
      policy: "unknown"
      summary: "[미구현·추후] [owner] 모이 아이템 선물"
    }
  }

  CashGifts: {
    label: "CashGifts"

    createCashGift: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/cash-gifts"
      policy: "public"
      summary: "축의금 기록"
    }
    listCashGifts: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/weddings/{weddingId}/cash-gifts"
      policy: "auth"
      summary: "축의금 장부 목록"
    }
    hostCreateCashGift: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/weddings/{weddingId}/cash-gifts"
      policy: "auth"
      summary: "축의금 수동 추가 (호스트)"
    }
    getCashGiftsSummary: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/weddings/{weddingId}/cash-gifts/summary"
      policy: "auth"
      summary: "축의금 요약 (총액, 건수, 참석)"
    }
    updateCashGift: {
      shape: sql_table
      style.fill: "#f59e0b"
      method: "PATCH"
      path: "/weddings/{weddingId}/cash-gifts/{giftId}"
      policy: "auth"
      summary: "축의금 수정"
    }
    deleteCashGift: {
      shape: sql_table
      method: "DELETE"
      path: "/weddings/{weddingId}/cash-gifts/{giftId}"
      policy: "auth"
      summary: "축의금 삭제"
    }
  }

  HostInvites: {
    label: "HostInvites"

    listHostInvites: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/weddings/{weddingId}/host-invites"
      policy: "host"
      summary: "부모님 초대 목록"
    }
    createHostInvite: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/weddings/{weddingId}/host-invites"
      policy: "unknown"
      summary: "[host(신랑/신부)] 부모님 초대 생성"
    }
    getHostInvite: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/host-invites/{token}"
      policy: "public"
      summary: "초대 정보 조회"
    }
    acceptHostInvite: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/host-invites/{token}/accept"
      policy: "authenticated"
      summary: "초대 수락"
    }
    cancelHostInvite: {
      shape: sql_table
      method: "DELETE"
      path: "/weddings/{weddingId}/host-invites/{inviteId}"
      policy: "unknown"
      summary: "[host(신랑/신부)] 초대 취소 (pending만)"
    }
  }

  Iums: {
    label: "Iums"

    createIum: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/iums"
      policy: "unknown"
      summary: "[미구현·추후] [authenticated] 이음 생성"
    }
    deleteIum: {
      shape: sql_table
      method: "DELETE"
      path: "/iums/{iumId}"
      policy: "unknown"
      summary: "[미구현·추후] [owner] 이음 삭제"
    }
  }

  Uploads: {
    label: "Uploads"

    uploadFile: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/uploads"
      policy: "unknown"
      summary: "[authenticated·deprecated] (구) multipart 이미지 업로드. Photo Sharing에서 createPresignedUpload로 대체. memory FEED 리팩토링까지 한시 공존 후 제거 예정"
    }
    createPresignedUpload: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/uploads/presigned"
      policy: "authenticated"
      summary: "presigned upload URL 발급. category별 권한 검증 후 Supabase Storage SignedUploadUrl 반환. share는 object_key의 guestUserId를 ctx user로 서버 강제 주입"
    }
  }

  memories: {
    label: "memories"

    createMemory: {
      shape: sql_table
      style.fill: "#ef4444"
      method: "POST"
      path: "/memories"
      policy: "unknown"
      summary: "Memory 작성 (라운지 V2 게시물)"
    }
    listMemories: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/lounges/{loungeId}/memories"
      policy: "unknown"
      summary: "라운지의 Memory 목록 (최근순)"
    }
    deleteMemory: {
      shape: sql_table
      method: "DELETE"
      path: "/memories/{memoryId}"
      policy: "unknown"
      summary: "Memory 삭제 (본인만 soft delete)"
    }
  }

  MemoryBook: {
    label: "MemoryBook"

    getWeddingMemoryBook: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/weddings/{weddingId}/memory-book"
      policy: "host"
      summary: "웨딩메모리북 조회 (큐레이션 사진 + 모청 사진 + 자동선별 메시지 + 통계)"
    }
    replaceWeddingMemoryBookPhotos: {
      shape: sql_table
      method: "PUT"
      path: "/weddings/{weddingId}/memory-book/photos"
      policy: "host"
      summary: "큐레이션 사진 일괄 교체 (최대 30장, 원자적 DELETE+INSERT)"
    }
  }

  SharedPhotos: {
    label: "SharedPhotos"

    getWeddingSharedPhotoGroups: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/weddings/{weddingId}/shared-photo-groups"
      policy: "host"
      summary: "wedding의 모든 라운지의 공유 사진을 게스트별 그룹으로 묶어 반환 (메모리북 큐레이션용)"
    }
  }

  Admin: {
    label: "Admin"

    listAdminUsers: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/admin/users"
      policy: "admin"
      summary: "유저 목록"
    }
    getAdminUser: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/admin/users/{userId}"
      policy: "admin"
      summary: "유저 상세"
    }
    listAdminUserActivities: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/admin/users/{userId}/activities"
      policy: "admin"
      summary: "유저 게스트 활동 목록"
    }
    getAdminDashboardStats: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/admin/dashboard/stats"
      policy: "admin"
      summary: "대시보드 통계 (KST 기준)"
    }
    getAdminDashboardRecent: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/admin/dashboard/recent"
      policy: "admin"
      summary: "최근 가입·생성 5건"
    }
    getAdminDashboardHealth: {
      shape: sql_table
      style.fill: "#16a34a"
      method: "GET"
      path: "/admin/dashboard/health"
      policy: "admin"
      summary: "데이터 헬스체크"
    }
  }

}

schemas: {
  label: "Schemas"

  getMe_resp: {
    shape: sql_table
    id: "string (uuid)" {constraint: required}
    name: "string" {constraint: required}
    email: "string (email)" {constraint: required}
    phone: "string"
    profile_image_url: "string"
    created_at: "string (date-time)" {constraint: required}
  }
  getMe_resp.label: "User"

  updateMe_req: {
    shape: sql_table
