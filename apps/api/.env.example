# apps/api (Go 백엔드) 런타임 환경변수.
# 본 파일을 .env 로 복사 후 실 값 채움. .env 는 git ignore.
# 컨벤션: _code_convention/ENV_MANAGEMENT.md
# 적용 범위: apps/api/main.go + apps/api/cmd/{migrate-photos,rebucket-photos}/main.go

# ──────────────────────────────────────────────────────────
# DB / 서버 (필수)
# ──────────────────────────────────────────────────────────
# Postgres 연결 문자열 — 로컬은 supabase start 풀스택의 54322 포트 사용.
# 로컬 예: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# HTTP 리슨 포트. 미설정 시 fallback: 8080.
# 멀티포트 독립 기동 규약: .env.localhost=8080 / .env.dev=8081 / .env.prod=8082.
# 기동: `pnpm dev:api:local` / `pnpm dev:api:dev` / `pnpm dev:api:prod` (내부적으로 go run . -env <name>).
PORT=

# ──────────────────────────────────────────────────────────
# Supabase (필수)
# ──────────────────────────────────────────────────────────
# JWT 검증·세션·실시간에서 사용.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# admin/storage/마이그 도구가 service_role 권한으로 호출하는 키. 비밀 유지.
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────
# Admin / CORS (필수)
# ──────────────────────────────────────────────────────────
# /admin/* 경로 허용 이메일 — 콤마 구분. 예: admin1@example.com,admin2@example.com
ADMIN_EMAIL=

# CORS 허용 origin — 콤마 구분. 예: http://localhost:5200,http://localhost:5201
ALLOWED_ORIGINS=

# ──────────────────────────────────────────────────────────
# Upload (필수)
# ──────────────────────────────────────────────────────────
# 업로드 드라이버. 미설정(권장)=Supabase Storage. "local"은 레거시 GET /uploads/* 서빙
# 확인용 — presigned 발급이 503이 되어 업로드 자체가 불가 (POST /uploads는 2026-06-10 폐기).
UPLOAD_DRIVER=

# 공개 버킷 이름 (예: wedding-photos)
UPLOAD_BUCKET_PUBLIC=

# 비공개 버킷 이름 (예: wedding-photos-private)
UPLOAD_BUCKET_PRIVATE=

# === zkLogin (Salt 서버) ===
# Salt 도출 master secret. 유출 시 전체 zkLogin 주소 매핑 노출 → 절대 커밋/로그 금지.
# 미설정 시 POST /zklogin/salt 비활성.
ZKLOGIN_MASTER_SECRET=
# Google OAuth client id (= ID 토큰 audience). 검증 시 aud 일치 확인용.
GOOGLE_CLIENT_ID=

# === Sponsored Transaction (가스 대납) ===
# sponsor 키페어 비밀키(bech32 suiprivkey...). 미설정 시 POST /sponsor/execute 비활성. 절대 커밋/로그 금지.
SPONSOR_PRIVATE_KEY=
# 기본 가스 예산(MIST)
SPONSOR_GAS_BUDGET=30000000
# Sui 네트워크 + 허용 패키지 ID(이 패키지의 moveCall만 대납)
SUI_NETWORK=testnet
SUI_PACKAGE_ID=
