# apps/guest-web 런타임 환경변수.
# 본 파일을 .env (또는 .env.local) 로 복사 후 실 값 채움. .env 는 git ignore.
# 컨벤션: _code_convention/ENV_MANAGEMENT.md
# 환경 전환: scripts/use-env.sh local|dev|prod
# E2E 테스트용 env는 .env.test.example 참고.

# ──────────────────────────────────────────────────────────
# Supabase (필수)
# ──────────────────────────────────────────────────────────
# anon key로 직접 SELECT/Realtime 구독. RLS 정책은 supabase/migrations 참조.
# 미설정 시 getSupabaseClient() 첫 호출 시점에 throw.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────────
# 외부 URL (선택 — 미설정 시 로컬 기본값으로 폴백)
# ──────────────────────────────────────────────────────────
# guest-web 자체의 base URL. QR·공유 링크 생성에 사용.
# 로컬 미설정 시 fallback: http://localhost:5173
VITE_BASE_URL=

# Dibang Wedding(본체) 사이트 URL — guest-web에서 본체로 유도 시 사용.
# 로컬 미설정 시 fallback: http://localhost:5200
VITE_DIBANG_URL=

# Go API base URL (@gorae/contracts 런타임이 읽음). 멀티포트: LOCAL 8080 / DEV 8081 / PROD 8082.
VITE_API_BASE_URL=http://localhost:8081
