# apps/dibang-wedding 런타임 환경변수.
# 본 파일을 .env (또는 .env.local) 로 복사 후 실 값 채움. .env 는 git ignore.
# 컨벤션: _code_convention/ENV_MANAGEMENT.md
# 환경 전환: scripts/use-env.sh local|dev|prod

# ──────────────────────────────────────────────────────────
# Supabase (필수)
# ──────────────────────────────────────────────────────────
# 로그인·세션·실시간 모두 anon key 사용. RLS 정책은 supabase/migrations 참조.
# 미설정 시 getSupabaseClient() 첫 호출 시점에 throw.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ──────────────────────────────────────────────────────────
# 외부 URL (선택 — 미설정 시 로컬 기본값으로 폴백)
# ──────────────────────────────────────────────────────────
# 백엔드 API base URL — 공유 사진 ZIP 다운로드 등에서 사용.
# 로컬 미설정 시 fallback: http://localhost:8080
VITE_API_BASE_URL=

# Guest Web 사이트 URL — display 페이지 링크, QR 등 생성에 사용.
# 로컬 미설정 시 fallback: http://localhost:5201
VITE_GUEST_WEB_URL=

# OAuth redirect 등에서 사용할 본 사이트 URL.
# 로컬 미설정 시 fallback: window.location.origin
VITE_SITE_URL=

# ──────────────────────────────────────────────────────────
# Sui 온체인 (선택 — 미설정 시 @gorae/sui-sdk testnet 기본값)
# ──────────────────────────────────────────────────────────
VITE_SUI_NETWORK=testnet
VITE_SUI_PACKAGE_ID=

# ──────────────────────────────────────────────────────────
# zkLogin / Google OAuth (선택)
# ──────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=
VITE_ZK_PROVER_URL=
VITE_ENOKI_API_KEY=
VITE_SALT_SERVER_URL=

# ──────────────────────────────────────────────────────────
# DEV 전용 (선택 — 프로덕션에서는 설정하지 않음)
# ──────────────────────────────────────────────────────────
# VITE_DEV_PRIVATE_KEY=
